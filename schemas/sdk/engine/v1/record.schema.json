{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidetic.local/contracts/engine/v1/record.schema.json",
  "title": "Eidetic Engine source record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_id", "object_id", "title", "kind", "text"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "object_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "title": {"type": "string", "maxLength": 4096},
    "kind": {"type": "string", "minLength": 1, "maxLength": 128},
    "text": {"type": "string", "minLength": 1, "maxLength": 1000000}
  }
}
